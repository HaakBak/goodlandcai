# ============================================================================
# ENVIRONMENT VARIABLES - GoodLand Cafe POS System
# ============================================================================
# TEMPLATE: Copy this file to .env and fill in your actual values
# WARNING: NEVER commit .env file — it contains secrets!
# Add .env to .gitignore to prevent accidental commits
# ============================================================================

# ============================================================================
# SUPABASE CONFIGURATION (Cloud Database & Optional Auth)
# ============================================================================
# Get these values from: Supabase Dashboard → Settings → API

# Your Supabase project URL
# Format: https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous (public) key
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# BUSINESS INFORMATION (Optional — can be set in app later)
# ============================================================================

# Tax Identification Number
VITE_BUSINESS_TIN=908-767-876-000

# Business phone number
VITE_BUSINESS_PHONE=(239) 555-0298

# Business name
VITE_BUSINESS_NAME=GoodLand Cafe

# ============================================================================
# AUTHENTICATION (Default fallback credentials)
# ============================================================================
# In production, use Supabase Auth instead

# Default admin username (for development/testing only)
VITE_ADMIN_USERNAME=admin

# Default admin password (CHANGE THIS IN PRODUCTION!)
# Use a strong password: at least 12 characters with mixed case, numbers, symbols
VITE_ADMIN_PASSWORD=lukasbeneictas

# Optional: Admin email
VITE_ADMIN_EMAIL=admin@goodland.com

# ============================================================================
# API ENDPOINTS
# ============================================================================

# Backend API base URL (for future backend integration)
VITE_API_BASE_URL=http://localhost:5175

# API request timeout (milliseconds)
VITE_API_TIMEOUT=30000

# ============================================================================
# OFFLINE-FIRST MODE
# ============================================================================
# Enable hybrid architecture: Supabase primary + offline fallback

# Set to 'true' to allow offline-first mode (default: true)
# When true: App continues working offline, auto-syncs when network returns
# Set to 'false' to disable offline mode (require Supabase always)
VITE_OFFLINE_MODE=true

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application environment: 'development' or 'production'
VITE_APP_ENV=development

# Application name (displayed in UI)
VITE_APP_NAME=GoodLand Cafe

# Application version
VITE_APP_VERSION=1.0.0

# ============================================================================
# DEBUG AND LOGGING
# ============================================================================
# Production: Set to 'false' to reduce console noise and improve performance

# Enable debug mode (logs extra info to console)
VITE_DEBUG_MODE=true

# Log level: 'debug', 'info', 'warn', 'error'
VITE_LOG_LEVEL=debug

# ============================================================================
# EMAIL SERVICE (Future Implementation)
# ============================================================================
# Supported services: sendgrid, aws_ses, mailgun
# Uncomment and configure when email notifications are needed

# Email service provider
# VITE_EMAIL_SERVICE=sendgrid

# Email API key
# VITE_EMAIL_API_KEY=sg_live_your_key_here

# From email address
# VITE_EMAIL_FROM=noreply@goodlandcafe.com

# ============================================================================
# PAYMENT GATEWAY (Future Implementation)
# ============================================================================
# Supported providers: stripe, paypal
# Uncomment and configure when payment integration is needed

# Payment provider
# VITE_PAYMENT_PROVIDER=stripe

# Payment provider public key
# VITE_PAYMENT_PUBLIC_KEY=pk_live_your_public_key

# ============================================================================
# ANALYTICS & MONITORING (Future Implementation)
# ============================================================================
# Uncomment and configure when analytics are needed

# Google Analytics ID
# VITE_ANALYTICS_ID=UA-XXXXX-X

# Sentry error tracking DSN
# VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY (required)
# 3. Optional: Update business info and credentials
# 4. Save .env
# 5. Run: npm run dev
# 6. Never commit .env file!
#

